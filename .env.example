# =======================================================
# Configuration SMTP pour le formulaire de contact
# Copier ce fichier en .env et remplir les valeurs réelles
# Le fichier .env NE DOIT JAMAIS être commité (gitignore)
# Et NE DOIT JAMAIS être servi par HTTP (htaccess bloque déjà)
# =======================================================

SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=changeme
SMTP_FROM=noreply@example.com

# Destinataires du formulaire de contact (séparés sur deux lignes)
SMTP_TO_PRIMARY=destinataire1@example.com
SMTP_TO_SECONDARY=destinataire2@example.com
